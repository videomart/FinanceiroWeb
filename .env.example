# Copie este arquivo para .env e ajuste os valores conforme necessário.
# Usado por docker-compose.yml (via interpolação ${VAR:-default}) e por config.js.

# Porta em que o servidor escuta. Se 3002 já estiver ocupada no servidor,
# defina outra aqui (ex: PORT=3005) antes de rodar docker compose up -d.
PORT=3002

# URL de callback do Google OAuth. Ajuste para o domínio real do deploy
# (ou http://localhost:3002/auth/google/callback para teste local).
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback

# Credenciais do Google OAuth (obtidas em https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP para notificações por email de contas a vencer (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
